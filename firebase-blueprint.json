{
  "entities": {
    "Opportunity": {
      "title": "Opportunity",
      "description": "A job, internship, hackathon, or scholarship opportunity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "category": { "type": "string", "enum": ["internship", "job", "hackathon", "scholarship", "other"] },
        "eligibility": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["company", "role", "category", "link"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "savedOpportunities": { "type": "array", "items": { "type": "string" } },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "whatsapp": { "type": "boolean" },
            "whatsappNumber": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/opportunities/{opportunityId}": {
      "schema": "Opportunity",
      "description": "Collection of all opportunities."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and preferences."
    }
  }
}
